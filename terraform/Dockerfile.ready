FROM ubuntu:20.04

# --- เพิ่มบรรทัดนี้เข้าไปครับ ---
ENV DEBIAN_FRONTEND=noninteractive

# ส่วนที่เหลือเหมือนเดิม แต่สังเกตตรง sudo นะครับ (ใน log บอสพิมพ์แค่ su)
RUN apt-get update && apt-get install -y \
    openssh-server \
    sudo \
    curl \
    wget \
    git \
    apt-transport-https \
    ca-certificates \
    software-properties-common \
    && mkdir -p /var/run/sshd \
    && rm -rf /var/lib/apt/lists/*

EXPOSE 22
CMD ["/usr/sbin/sshd", "-D"]